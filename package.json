{
  "name": "gidevo-api-tool",
  "version": "0.2.0",
  "description": "Agentic API integration and SDK generation CLI for OpenAPI and GraphQL projects.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gidevo-api-tool": "dist/cli/index.js"
  },
  "files": [
    "dist/**/*",
    "LICENSE*",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lehrosolutions/gidevo-api-tool.git"
  },
  "bugs": {
    "url": "https://github.com/lehrosolutions/gidevo-api-tool/issues"
  },
  "homepage": "https://github.com/lehrosolutions/gidevo-api-tool#readme",
  "scripts": {
    "build": "tsc && copyfiles -u 1 src/templates/**/*.hbs dist",
    "dev": "tsc --watch",
    "test": "bunx jest",
    "test:coverage": "bunx jest --coverage",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier -w \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,md,yml,yaml,js,cjs}\" \".github/workflows/*.yml\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,md,yml,yaml,js,cjs}\" \".github/workflows/*.yml\"",
    "prepare": "bun run build",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags",
    "release": "semantic-release",
    "package:manager": "bun --version",
    "install:js": "bun install",
    "docs:build": "node scripts/docs.mjs build",
    "docs:check": "node scripts/docs.mjs check"
  },
  "keywords": [
    "api",
    "integration",
    "openapi",
    "graphql",
    "sdk",
    "codegen",
    "cli",
    "developer-tools"
  ],
  "author": "LEHRO Solutions",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "copyfiles": "^2.4.1",
    "eslint": "^10.3.0",
    "jest": "^30.3.0",
    "prettier": "^3.5.3",
    "semantic-release": "^20.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^2.1.1",
    "axios": "^1.15.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "graphql": "^16.0.0",
    "handlebars": "^4.7.9",
    "js-yaml": "^4.1.1",
    "openapi-schema-validator": "^12.1.3",
    "openapi-types": "^12.0.0",
    "ora": "^9.4.0"
  },
  "overrides": {
    "follow-redirects": "1.16.0"
  },
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "examples/basic-typescript",
    "examples/sample-plugin"
  ]
}

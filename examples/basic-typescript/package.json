{
  "name": "petstore-typescript-example",
  "version": "1.0.0",
  "description": "Example TypeScript SDK generated from Petstore API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "gidevo-api-tool generate -s ../specs/petstore.yaml -l typescript -o ./src/generated",
    "build": "tsc",
    "example": "bun src/example.ts",
    "package:manager": "bun --version"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "ts-node": "^10.9.2",
    "@types/node": "^20.0.0"
  },
  "dependencies": {
    "gidevo-api-tool": "^0.1.5"
  },
  "packageManager": "bun@1.2.19",
  "engines": {
    "node": ">=20",
    "bun": ">=1.1.0"
  },
  "license": "Apache-2.0"
}
